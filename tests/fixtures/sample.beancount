option "title" "Bean-Retire Sample Ledger"
option "operating_currency" "USD"

; ─── Owner directives ─────────────────────────────────────────────────────────

2020-01-01 custom "owner" "person1"
  birth-date: "1985-03-15"
  retirement-age: "57"
  social-security-age: "67"
  social-security-estimate: "2400"

2020-01-01 custom "owner" "person2"
  birth-date: "1987-06-20"
  retirement-age: "55"
  social-security-age: "67"
  social-security-estimate: "1800"

; ─── Accounts ─────────────────────────────────────────────────────────────────

2020-01-01 open Equity:Stub

2020-01-01 open Assets:Investment:Retirement:Person1s-401k USD
  account-owner: "person1"
  tax-account-type: "split"
  traditional-percent: "65"
  roth-percent: "35"

2020-01-01 open Assets:Investment:Retirement:Person1s-Roth-IRA USD
  account-owner: "person1"
  tax-account-type: "roth"

2020-01-01 open Assets:Investment:Retirement:Person2s-403b USD
  account-owner: "person2"
  tax-account-type: "traditional"

2020-01-01 open Expenses:Housing USD
2020-01-01 open Expenses:Food USD
2020-01-01 open Expenses:Transport USD

; ─── Opening retirement balances ──────────────────────────────────────────────
; Person1: $200k (150k 401k + 50k Roth), Person2: $80k (403b)

2020-01-01 * "Opening retirement balances"
  Assets:Investment:Retirement:Person1s-401k       150000.00 USD
  Assets:Investment:Retirement:Person1s-Roth-IRA    50000.00 USD
  Assets:Investment:Retirement:Person2s-403b       80000.00 USD
  Equity:Stub                                 -280000.00 USD

; ─── Annual retirement contributions ──────────────────────────────────────────
; Person1: $18k/yr 401k + $7k/yr Roth = $25k/yr
; Person2: $10k/yr 403b
; Contributions dated mid-year so the 2-year trailing window (cutoff 2024-03-20)
; captures both 2024 and 2025 contributions.

2022-06-15 * "2022 Person1 retirement contributions"
  Assets:Investment:Retirement:Person1s-401k        18000.00 USD
  Assets:Investment:Retirement:Person1s-Roth-IRA     7000.00 USD
  Equity:Stub                                  -25000.00 USD

2022-06-15 * "2022 Person2 retirement contribution"
  Assets:Investment:Retirement:Person2s-403b       10000.00 USD
  Equity:Stub                                  -10000.00 USD

2023-06-15 * "2023 Person1 retirement contributions"
